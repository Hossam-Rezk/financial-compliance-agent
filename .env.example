APP_NAME="mini-rag-app"
APP_VERSION="0.1.0"
APP_DESCRIPTION="A mini RAG (Retrieval-Augmented Generation) application built with FastAPI."
FILE_ALLOWED_TYPES=["application/pdf","text/plain","application/docx"]
FILE_MAX_SIZE=10485760
FILE_DEFAULT_CHUNK_SIZE=512
FILE_DEFAULT_OVERLAP_SIZE=50
# Ollama (kept for embeddings)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_EMBED_MODEL=nomic-embed-text

# Groq (used for fast generation)
GROQ_API_KEY="your_groq_api_key_here"
GROQ_MODEL="llama-3.3-70b-versatile"

QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION_NAME=financial_compliance
VECTOR_EMBEDDING_SIZE=768
MONGO_DB_URL=mongodb://localhost:27017
MONGO_DATABASE=financial_compliance
